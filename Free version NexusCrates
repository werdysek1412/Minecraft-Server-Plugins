@SuppressWarnings("deprecation")
public final class NexusCrates extends JavaPlugin implements Listener, CommandExecutor, TabCompleter {

    private static NexusCrates instance;
    private ConfigManager configManager;
    private HologramManager hologramManager;
    private GUIManager guiManager;

    @Override
    public void onEnable() {
        instance = this;
        this.configManager = new ConfigManager(this);
        this.hologramManager = new HologramManager(this);
        this.guiManager = new GUIManager(this);

        getServer().getPluginManager().registerEvents(this, this);
        getServer().getPluginManager().registerEvents(guiManager, this);

        if (getCommand("nexus") != null) {
            getCommand("nexus").setExecutor(this);
            getCommand("nexus").setTabCompleter(this);
        }

        Bukkit.getScheduler().runTaskLater(this, () -> hologramManager.respawnAllHolograms(), 20L);
        getLogger().info("NexusCrates PRO MAX v7 (CLEAN LAYOUT) - Loaded!");
    }

    @Override
    public void onDisable() {
        if (configManager != null) configManager.saveAll();
        if (hologramManager != null) hologramManager.removeAllHolograms();
        getLogger().info("NexusCrates Disabled! Data saved and holograms removed safely.");
    }

    public static NexusCrates getInstance() { return instance; }
    public ConfigManager getConfigManager() { return configManager; }
    public HologramManager getHologramManager() { return hologramManager; }
    public GUIManager getGuiManager() { return guiManager; }

    @Override
    public boolean onCommand(CommandSender sender, Command cmd, String label, String[] args) {
        if (!sender.isOp() && !sender.hasPermission("nexuscrates.admin")) {
            sender.sendMessage(configManager.getPrefix() + " §cYou don't have permission!");
            return true;
        }

        if (args.length == 0 || args[0].equalsIgnoreCase("help")) {
            sender.sendMessage("§8§m--------------------------------");
            sender.sendMessage("§b§lNexusCrates §7- Admin Panel");
            sender.sendMessage("§e/nexus admin §7- Open Admin GUI");
            sender.sendMessage("§e/nexus create <id> §7- Create new crate setup");
            sender.sendMessage("§e/nexus setcrate <id> §7- Set crate on target block");
            sender.sendMessage("§e/nexus removecrate §7- Remove targeted crate");
            sender.sendMessage("§e/nexus addreward <id> <chance> <bc> §7- Add hand item");
            sender.sendMessage("§e/nexus removereward <id> <index> §7- Remove item");
            sender.sendMessage("§e/nexus listrewards <id> §7- List all rewards in crate");
            sender.sendMessage("§e/nexus key <player> <id> <amount> §7- Give keys");
            sender.sendMessage("§e/nexus keyall <id> <amount> §7- Give keys to everyone");
            sender.sendMessage("§e/nexus reload §7- Reload configs");
            sender.sendMessage("§8§m--------------------------------");
            return true;
        }

        if (args[0].equalsIgnoreCase("admin") && sender instanceof Player) {
            guiManager.openAdminGUI((Player) sender);
            return true;
        }

        if (args[0].equalsIgnoreCase("create")) {
            if (args.length < 2) {
                sender.sendMessage(configManager.getPrefix() + " §cUsage: /nexus create <id>");
                return true;
            }
            String crateId = args[1].toLowerCase();
            if (configManager.crateExists(crateId)) {
                sender.sendMessage(configManager.getPrefix() + " §cCrate '"+crateId+"' already exists!");
                return true;
            }
            configManager.createCrate(crateId);
            sender.sendMessage(configManager.getPrefix() + " §aCrate '§l" + crateId.toUpperCase() + "§a' created successfully! You can now add rewards.");
            if (sender instanceof Player) ((Player) sender).playSound(((Player) sender).getLocation(), Sound.ENTITY_PLAYER_LEVELUP, 1f, 1f);
            return true;
        }

        if (args[0].equalsIgnoreCase("listrewards")) {
            if (args.length < 2) {
                sender.sendMessage(configManager.getPrefix() + " §cUsage: /nexus listrewards <crate>");
                return true;
            }
            configManager.listRewards(sender, args[1]);
            return true;
        }

        if (args[0].equalsIgnoreCase("removereward")) {
            if (args.length < 3) {
                sender.sendMessage(configManager.getPrefix() + " §cUsage: /nexus removereward <crate> <index>");
                return true;
            }
            configManager.removeRewardFromCrate(sender, args[1], args[2]);
            return true;
        }

        if (args[0].equalsIgnoreCase("addreward") && sender instanceof Player) {
            Player p = (Player) sender;
            if (args.length < 4) {
                p.sendMessage(configManager.getPrefix() + " §cUsage: /nexus addreward <crate> <chance> <true/false>");
                return true;
            }
            String crateId = args[1];
            if (!configManager.crateExists(crateId)) {
                p.sendMessage(configManager.getPrefix() + " §cCrate does not exist! Use §e/nexus create " + crateId + " §cfirst.");
                return true;
            }

            ItemStack handItem = p.getInventory().getItemInMainHand();
            if (handItem.getType() == Material.AIR) {
                p.sendMessage(configManager.getPrefix() + " §cYou must hold an item!");
                return true;
            }

            try {
                double chance = Double.parseDouble(args[2]);
                boolean broadcast = Boolean.parseBoolean(args[3]);
                configManager.addRewardToCrate(crateId, handItem, chance, broadcast);
                p.sendMessage(configManager.getPrefix() + " §aItem added successfully to crate §l" + crateId.toUpperCase() + "§a!");
                p.playSound(p.getLocation(), Sound.ENTITY_EXPERIENCE_ORB_PICKUP, 1f, 1f);
            } catch (NumberFormatException e) {
                p.sendMessage(configManager.getPrefix() + " §cChance must be a valid number (e.g. 5.5)!");
            }
        }
        else if (args[0].equalsIgnoreCase("setcrate") && sender instanceof Player) {
            if (args.length < 2) return true;
            Player p = (Player) sender;
            Block b = p.getTargetBlockExact(5);
            if (b == null || b.getType() == Material.AIR) {
                p.sendMessage(configManager.getPrefix() + " §cYou must look at a block!");
                return true;
            }
            if (!configManager.crateExists(args[1])) {
                p.sendMessage(configManager.getPrefix() + " §cCrate not found! Use §e/nexus create " + args[1]);
                return true;
            }
            configManager.setBlockAsCrate(b.getLocation(), args[1]);
            hologramManager.spawnHologram(b.getLocation(), args[1]);
            p.sendMessage(configManager.getPrefix() + " §aCrate placed successfully!");
        }
        else if (args[0].equalsIgnoreCase("removecrate") && sender instanceof Player) {
            Player p = (Player) sender;
            Block b = p.getTargetBlockExact(5);
            if (b == null || b.getType() == Material.AIR) {
                p.sendMessage(configManager.getPrefix() + " §cLook at a crate to remove it!");
                return true;
            }
            if (configManager.getCrateAt(b.getLocation()) != null) {
                configManager.removeCrate(b.getLocation());
                hologramManager.removeHologramAt(b.getLocation());
                p.sendMessage(configManager.getPrefix() + " §aCrate removed successfully!");
                p.playSound(p.getLocation(), Sound.BLOCK_NOTE_BLOCK_BASS, 1f, 1f);
            } else {
                p.sendMessage(configManager.getPrefix() + " §cThis block is not a crate.");
            }
        }
        else if (args[0].equalsIgnoreCase("key")) {
            if (args.length < 4) return true;
            Player target = Bukkit.getPlayer(args[1]);
            if (target == null || !configManager.crateExists(args[2])) return true;
            try {
                int amount = Integer.parseInt(args[3]);
                target.getInventory().addItem(configManager.generateKey(args[2], amount));
                sender.sendMessage(configManager.getPrefix() + " §aKeys given to " + target.getName() + ".");
            } catch (NumberFormatException ignored) {}
        }
        else if (args[0].equalsIgnoreCase("keyall")) {
            if (args.length < 3) return true;
            if (!configManager.crateExists(args[1])) return true;
            try {
                int amount = Integer.parseInt(args[2]);
                ItemStack key = configManager.generateKey(args[1], amount);
                for (Player p : Bukkit.getOnlinePlayers()) {
                    p.getInventory().addItem(key);
                    p.sendMessage(configManager.getPrefix() + " §aYou received " + amount + "x " + args[1].toUpperCase() + " key from an admin!");
                    p.playSound(p.getLocation(), Sound.ENTITY_PLAYER_LEVELUP, 1f, 1f);
                }
                sender.sendMessage(configManager.getPrefix() + " §aKeys given to ALL online players.");
            } catch (NumberFormatException ignored) {}
        }
        else if (args[0].equalsIgnoreCase("reload")) {
            hologramManager.removeAllHolograms();
            configManager.loadConfigs();
            hologramManager.respawnAllHolograms();
            sender.sendMessage(configManager.getPrefix() + " §aConfigs and holograms reloaded!");
        }
        return true;
    }

    @Override
    public List<String> onTabComplete(CommandSender sender, Command cmd, String alias, String[] args) {
        List<String> completions = new ArrayList<>();
        if (!sender.isOp()) return completions;

        if (args.length == 1) {
            for (String s : Arrays.asList("help", "admin", "create", "setcrate", "removecrate", "addreward", "removereward", "listrewards", "key", "keyall", "reload")) {
                if (s.startsWith(args[0].toLowerCase())) completions.add(s);
            }
        } else if (args.length == 2 && Arrays.asList("addreward", "setcrate", "listrewards", "removereward", "keyall").contains(args[0].toLowerCase())) {
            for (String cId : configManager.getAvailableCrates()) {
                if (cId.startsWith(args[1].toLowerCase())) completions.add(cId);
            }
        }
        return completions;
    }

    @EventHandler
    public void onKeyPlace(BlockPlaceEvent e) {
        ItemStack item = e.getItemInHand();
        if (configManager.getKeyId(item) != null) {
            e.setCancelled(true);
            e.getPlayer().sendMessage(configManager.getPrefix() + " §cYou cannot place crate keys!");
        }
    }

    @EventHandler(priority = EventPriority.HIGHEST)
    public void onCrateInteract(PlayerInteractEvent e) {
        if (e.getHand() != EquipmentSlot.HAND || e.getClickedBlock() == null) return;

        Location loc = e.getClickedBlock().getLocation();
        String crateId = configManager.getCrateAt(loc);
        if (crateId == null) return;

        e.setCancelled(true);
        Player p = e.getPlayer();

        if (e.getAction() == Action.LEFT_CLICK_BLOCK) {
            guiManager.openPreviewGUI(p, crateId);
            return;
        }

        if (e.getAction() == Action.RIGHT_CLICK_BLOCK) {
            if (AnimationManager.isAnimating(loc)) {
                p.sendMessage(configManager.getPrefix() + " §cThis crate is currently opening.");
                return;
            }

            ItemStack hand = p.getInventory().getItemInMainHand();
            String keyId = configManager.getKeyId(hand);

            if (keyId == null || !keyId.equalsIgnoreCase(crateId)) {
                p.sendMessage(configManager.getPrefix() + " §cYou need a §l" + crateId.toUpperCase() + " §ckey!");
                p.playSound(loc, Sound.BLOCK_CHEST_LOCKED, 1f, 1f);
                return;
            }

            hand.setAmount(hand.getAmount() - 1);

            CrateReward reward = configManager.getRandomReward(crateId);
            if (reward == null) {
                p.sendMessage(configManager.getPrefix() + " §cThis crate has no rewards setup!");
                return;
            }

            hologramManager.hideHologramTemporarily(loc);
            AnimationManager.playAnimation(p, loc, configManager.getAllRewards(crateId), reward, configManager.getCrateData(crateId).animationType);
        }
    }

    @EventHandler
    public void onCrateBreak(BlockBreakEvent e) {
        Location loc = e.getBlock().getLocation();
        if (configManager.getCrateAt(loc) != null) {
            e.setCancelled(true);
            if (e.getPlayer().isOp()) {
                e.getPlayer().sendMessage(configManager.getPrefix() + " §cUse §e/nexus removecrate §cwhile looking at it to delete.");
            }
        }
    }
}

@SuppressWarnings("deprecation")
class ConfigManager {
    private final NexusCrates plugin;
    private final NamespacedKey keyTag;

    private File mainFile, cratesFile, locsFile;
    private FileConfiguration mainConfig, cratesConfig, locsConfig;

    private final Map<Location, String> activeLocations = new HashMap<>();
    private final Map<String, CrateModel> cratesData = new HashMap<>();
    private String prefix = "§8[§bNexusCrates§8]";

    public ConfigManager(NexusCrates plugin) {
        this.plugin = plugin;
        this.keyTag = new NamespacedKey(plugin, "nexus_key");
        loadConfigs();
    }

    public void loadConfigs() {
        if (!plugin.getDataFolder().exists()) plugin.getDataFolder().mkdir();

        mainFile = new File(plugin.getDataFolder(), "config.yml");
        if (!mainFile.exists()) createDefaultMainConfig();
        mainConfig = YamlConfiguration.loadConfiguration(mainFile);
        prefix = ChatColor.translateAlternateColorCodes('&', mainConfig.getString("prefix", "&8[&bNexusCrates&8]"));

        cratesFile = new File(plugin.getDataFolder(), "crates.yml");
        if (!cratesFile.exists()) createDefaultCratesConfig();
        cratesConfig = YamlConfiguration.loadConfiguration(cratesFile);

        locsFile = new File(plugin.getDataFolder(), "locations.yml");
        if (!locsFile.exists()) { try { locsFile.createNewFile(); } catch (IOException ignored) {} }
        locsConfig = YamlConfiguration.loadConfiguration(locsFile);

        loadLootTables();
        loadLocations();
    }

    public void saveAll() {
        try {
            if (cratesConfig != null && cratesFile != null) cratesConfig.save(cratesFile);
            if (locsConfig != null && locsFile != null) locsConfig.save(locsFile);
        } catch (IOException e) {
            plugin.getLogger().severe("Failed to save configs!");
        }
    }

    private void createDefaultMainConfig() {
        mainConfig = new YamlConfiguration();
        mainConfig.set("prefix", "&8[&bNexusCrates&8]");
        mainConfig.set("broadcast_message", "&e%player% just won %reward% &efrom %crate%!");
        try { mainConfig.save(mainFile); } catch (IOException ignored) {}
    }

    private void createDefaultCratesConfig() {
        cratesConfig = new YamlConfiguration();
        cratesConfig.set("crates.csgo.name", "&e&lCS:GO Case");
        cratesConfig.set("crates.csgo.animation", "CS2_SCROLL");
        cratesConfig.set("crates.csgo.hologram", Arrays.asList("&e&lCS:GO Weapon Case", "&7Right-Click to Open", "&7Left-Click to Preview"));

        ItemStack knife = new ItemStack(Material.IRON_SWORD);
        ItemMeta meta = knife.getItemMeta();
        meta.setDisplayName("§e★ Karambit | Fade");
        meta.addEnchant(Enchantment.SHARPNESS, 5, true);
        knife.setItemMeta(meta);

        cratesConfig.set("crates.csgo.rewards.1.item", knife);
        cratesConfig.set("crates.csgo.rewards.1.chance", 1.5);
        cratesConfig.set("crates.csgo.rewards.1.broadcast", true);

        try { cratesConfig.save(cratesFile); } catch (IOException ignored) {}
    }

    public void createCrate(String crateId) {
        cratesConfig.set("crates." + crateId + ".name", "&b&l" + crateId.toUpperCase() + " Crate");
        cratesConfig.set("crates." + crateId + ".animation", "CS2_SCROLL");
        cratesConfig.set("crates." + crateId + ".hologram", Arrays.asList("&b&l" + crateId.toUpperCase() + " Crate", "&7Right-Click to Open", "&7Left-Click to Preview"));
        saveAll();
        loadLootTables();
    }

    private void loadLootTables() {
        cratesData.clear();
        ConfigurationSection cratesSec = cratesConfig.getConfigurationSection("crates");
        if (cratesSec == null) return;

        for (String crateId : cratesSec.getKeys(false)) {
            String anim = cratesConfig.getString("crates." + crateId + ".animation", "CS2_SCROLL");
            String guiName = cratesConfig.getString("crates." + crateId + ".name", crateId);
            List<String> holo = cratesConfig.getStringList("crates." + crateId + ".hologram");
            List<CrateReward> rewards = new ArrayList<>();

            ConfigurationSection rewSec = cratesConfig.getConfigurationSection("crates." + crateId + ".rewards");
            if (rewSec != null) {
                for (String rewKey : rewSec.getKeys(false)) {
                    ItemStack displayItem = rewSec.getItemStack(rewKey + ".item");
                    if (displayItem == null) continue;
                    double chance = rewSec.getDouble(rewKey + ".chance", 10.0);
                    boolean bc = rewSec.getBoolean(rewKey + ".broadcast", false);
                    rewards.add(new CrateReward(rewKey, displayItem.clone(), chance, bc));
                }
            }
            cratesData.put(crateId.toLowerCase(), new CrateModel(crateId, ChatColor.translateAlternateColorCodes('&', guiName), anim, holo, rewards));
        }
    }

    public void listRewards(CommandSender sender, String crateId) {
        if (!crateExists(crateId)) { sender.sendMessage(prefix + " §cCrate not found."); return; }
        sender.sendMessage("§8§m--------------------------------");
        sender.sendMessage("§bRewards for Crate: §l" + crateId);
        for (CrateReward r : cratesData.get(crateId.toLowerCase()).rewards) {
            String name = r.displayItem.getItemMeta() != null && r.displayItem.getItemMeta().hasDisplayName() ? r.displayItem.getItemMeta().getDisplayName() : r.displayItem.getType().name();
            sender.sendMessage("§7[ID: §e" + r.configKey + "§7] §f" + name + " §8- §a" + r.chance + "%");
        }
        sender.sendMessage("§8§m--------------------------------");
    }

    public void removeRewardFromCrate(CommandSender sender, String crateId, String index) {
        if (!crateExists(crateId)) { sender.sendMessage(prefix + " §cCrate not found."); return; }
        String path = "crates." + crateId.toLowerCase() + ".rewards." + index;
        if (cratesConfig.contains(path)) {
            cratesConfig.set(path, null);
            saveAll();
            loadLootTables();
            sender.sendMessage(prefix + " §aReward ID " + index + " removed from crate " + crateId + ".");
        } else {
            sender.sendMessage(prefix + " §cReward ID " + index + " not found in that crate.");
        }
    }

    public void addRewardToCrate(String crateId, ItemStack item, double chance, boolean broadcast) {
        String pathBase = "crates." + crateId.toLowerCase() + ".rewards";
        ConfigurationSection sec = cratesConfig.getConfigurationSection(pathBase);
        int nextId = 1;
        if (sec != null) {
            for (String key : sec.getKeys(false)) {
                try {
                    int k = Integer.parseInt(key);
                    if (k >= nextId) nextId = k + 1;
                } catch (NumberFormatException ignored) {}
            }
        }
        String fullPath = pathBase + "." + nextId;
        cratesConfig.set(fullPath + ".item", item.clone());
        cratesConfig.set(fullPath + ".chance", chance);
        cratesConfig.set(fullPath + ".broadcast", broadcast);
        saveAll();
        loadLootTables();
    }

    private void loadLocations() {
        activeLocations.clear();
        ConfigurationSection sec = locsConfig.getConfigurationSection("locations");
        if (sec == null) return;
        for (String key : sec.getKeys(false)) {
            String path = "locations." + key + ".";
            World w = Bukkit.getWorld(locsConfig.getString(path + "world", "world"));
            if (w == null) continue;
            Location loc = new Location(w, locsConfig.getDouble(path+"x"), locsConfig.getDouble(path+"y"), locsConfig.getDouble(path+"z"));
            activeLocations.put(loc, locsConfig.getString(path + "id").toLowerCase());
        }
    }

    public void setBlockAsCrate(Location loc, String crateId) {
        activeLocations.put(loc, crateId.toLowerCase());
        String key = UUID.randomUUID().toString();
        locsConfig.set("locations." + key + ".world", loc.getWorld().getName());
        locsConfig.set("locations." + key + ".x", loc.getX());
        locsConfig.set("locations." + key + ".y", loc.getY());
        locsConfig.set("locations." + key + ".z", loc.getZ());
        locsConfig.set("locations." + key + ".id", crateId.toLowerCase());
        saveAll();
    }

    public void removeCrate(Location loc) {
        activeLocations.remove(loc);
        ConfigurationSection sec = locsConfig.getConfigurationSection("locations");
        if (sec != null) {
            for (String key : sec.getKeys(false)) {
                if (locsConfig.getDouble("locations."+key+".x") == loc.getX() && locsConfig.getDouble("locations."+key+".y") == loc.getY()) {
                    locsConfig.set("locations." + key, null);
                    saveAll();
                    break;
                }
            }
        }
    }

    public String getCrateAt(Location loc) { return activeLocations.get(loc); }
    public boolean crateExists(String id) { return cratesData.containsKey(id.toLowerCase()); }
    public Set<String> getAvailableCrates() { return cratesData.keySet(); }
    public CrateModel getCrateData(String id) { return cratesData.get(id.toLowerCase()); }
    public String getPrefix() { return prefix; }
    public Map<Location, String> getAllActiveLocations() { return activeLocations; }

    public ItemStack generateKey(String crateId, int amount) {
        ItemStack key = new ItemStack(Material.TRIPWIRE_HOOK, amount);
        ItemMeta meta = key.getItemMeta();
        if (meta != null) {
            meta.setDisplayName("§x§F§B§D§8§0§0✦ §l" + crateId.toUpperCase() + " KEY §r§x§F§B§D§8§0§0✦");
            meta.setLore(Arrays.asList("§7Opens crate: §e" + crateId, "", "§8[Nexus Security]"));
            meta.addEnchant(Enchantment.UNBREAKING, 1, true);
            meta.addItemFlags(ItemFlag.HIDE_ENCHANTS);
            meta.getPersistentDataContainer().set(keyTag, PersistentDataType.STRING, crateId.toLowerCase());
            key.setItemMeta(meta);
        }
        return key;
    }

    public String getKeyId(ItemStack item) {
        if (item == null || !item.hasItemMeta()) return null;
        return item.getItemMeta().getPersistentDataContainer().get(keyTag, PersistentDataType.STRING);
    }

    public List<CrateReward> getAllRewards(String crateId) {
        return cratesData.containsKey(crateId.toLowerCase()) ? cratesData.get(crateId.toLowerCase()).rewards : new ArrayList<>();
    }

    public CrateReward getRandomReward(String crateId) {
        List<CrateReward> rewards = getAllRewards(crateId);
        if (rewards.isEmpty()) return null;

        double totalWeight = 0.0;
        for (CrateReward r : rewards) totalWeight += r.chance;
        double random = Math.random() * totalWeight;
        for (CrateReward r : rewards) {
            random -= r.chance;
            if (random <= 0.0) return r;
        }
        return rewards.get(0);
    }

    public void triggerBroadcast(Player p, String crateId, CrateReward reward) {
        if (!reward.broadcast) return;
        String name = (reward.displayItem.getItemMeta() != null && reward.displayItem.getItemMeta().hasDisplayName()) ? reward.displayItem.getItemMeta().getDisplayName() : reward.displayItem.getType().name();
        String msg = mainConfig.getString("broadcast_message", "&e%player% won %reward%&e!");
        msg = msg.replace("%player%", p.getName())
                .replace("%reward%", name)
                .replace("%crate%", cratesData.get(crateId.toLowerCase()).guiName);
        Bukkit.broadcastMessage(ChatColor.translateAlternateColorCodes('&', msg));
    }
}

class CrateModel {
    public String id, guiName, animationType;
    public List<String> hologramLines;
    public List<CrateReward> rewards;
    public CrateModel(String id, String guiName, String anim, List<String> holo, List<CrateReward> rewards) {
        this.id = id; this.guiName = guiName; this.animationType = anim; this.hologramLines = holo; this.rewards = rewards;
    }
}

class CrateReward {
    public String configKey; public ItemStack displayItem; public double chance; public boolean broadcast;
    public CrateReward(String key, ItemStack d, double c, boolean bc) { this.configKey = key; this.displayItem = d; this.chance = c; this.broadcast = bc; }
}

class HologramManager {
    private final NexusCrates plugin;
    private final Map<Location, TextDisplay> textHolograms = new HashMap<>();
    private final Map<Location, ItemDisplay> itemIcons = new HashMap<>();

    private final Set<Location> hiddenForAnimation = new HashSet<>();

    public HologramManager(NexusCrates plugin) {
        this.plugin = plugin;

        new BukkitRunnable() {
            float angle = 0;
            @Override
            public void run() {
                angle += 0.05f;
                for (ItemDisplay icon : itemIcons.values()) {
                    if (icon != null && !icon.isDead()) {
                        float yOffset = (float) Math.sin(angle) * 0.1f;
                        icon.setTransformation(new Transformation(
                                new Vector3f(0, yOffset, 0),
                                new Quaternionf().rotateY(angle),
                                new Vector3f(0.8f, 0.8f, 0.8f),
                                new Quaternionf()
                        ));
                    }
                }
            }
        }.runTaskTimer(plugin, 0L, 1L);
    }

    public void respawnAllHolograms() {
        removeAllHolograms();
        for (Map.Entry<Location, String> entry : plugin.getConfigManager().getAllActiveLocations().entrySet()) {
            if (!hiddenForAnimation.contains(entry.getKey())) {
                spawnHologram(entry.getKey(), entry.getValue());
            }
        }
    }

    public void spawnHologram(Location blockLoc, String crateId) {
        if (hiddenForAnimation.contains(blockLoc)) return;

        CrateModel data = plugin.getConfigManager().getCrateData(crateId);
        if (data == null || data.hologramLines.isEmpty()) return;

        Location iconLoc = blockLoc.clone().add(0.5, 1.4, 0.5);
        ItemDisplay iconDisplay = iconLoc.getWorld().spawn(iconLoc, ItemDisplay.class, entity -> {
            entity.setItemStack(new ItemStack(Material.ENDER_CHEST));
            entity.setBillboard(Display.Billboard.FIXED);
        });
        itemIcons.put(blockLoc, iconDisplay);

        StringBuilder sb = new StringBuilder();
        for (String line : data.hologramLines) sb.append(ChatColor.translateAlternateColorCodes('&', line)).append("\n");

        Location holoLoc = blockLoc.clone().add(0.5, 2.4, 0.5);
        TextDisplay textDisplay = holoLoc.getWorld().spawn(holoLoc, TextDisplay.class, entity -> {
            entity.setText(sb.toString().trim());
            entity.setBillboard(Display.Billboard.CENTER);
            entity.setDefaultBackground(false);
            entity.setShadowed(true);
        });
        textHolograms.put(blockLoc, textDisplay);
    }

    public void removeHologramAt(Location loc) {
        if (textHolograms.containsKey(loc)) {
            TextDisplay td = textHolograms.get(loc);
            if (td != null && !td.isDead()) td.remove();
            textHolograms.remove(loc);
        }
        if (itemIcons.containsKey(loc)) {
            ItemDisplay id = itemIcons.get(loc);
            if (id != null && !id.isDead()) id.remove();
            itemIcons.remove(loc);
        }
    }

    public void removeAllHolograms() {
        for (TextDisplay td : textHolograms.values()) if (td != null && !td.isDead()) td.remove();
        textHolograms.clear();
        for (ItemDisplay id : itemIcons.values()) if (id != null && !id.isDead()) id.remove();
        itemIcons.clear();
    }

    public void hideHologramTemporarily(Location loc) {
        removeHologramAt(loc);
        hiddenForAnimation.add(loc);
    }

    public void unhideHologram(Location loc, String crateId) {
        hiddenForAnimation.remove(loc);
        spawnHologram(loc, crateId);
    }
}

class GUIManager implements Listener {
    private final NexusCrates plugin;

    public GUIManager(NexusCrates plugin) { this.plugin = plugin; }

    public void openAdminGUI(Player p) {
        Inventory gui = Bukkit.createInventory(null, 27, "§8NexusCrates - Admin Panel");
        int slot = 0;
        for (String crateId : plugin.getConfigManager().getAvailableCrates()) {
            CrateModel data = plugin.getConfigManager().getCrateData(crateId);
            ItemStack item = new ItemStack(Material.CHEST);
            ItemMeta meta = item.getItemMeta();
            if (meta != null) {
                meta.setDisplayName(data.guiName);
                meta.setLore(Arrays.asList("§7ID: §e" + crateId, "§7Animation: §b" + data.animationType, "", "§aLeft-Click §7to view rewards", "§cRight-Click §7to get a key"));
                meta.getPersistentDataContainer().set(new NamespacedKey(plugin, "admin_crate_id"), PersistentDataType.STRING, crateId);
                item.setItemMeta(meta);
            }
            gui.setItem(slot++, item);
        }
        p.openInventory(gui);
    }

    public void openPreviewGUI(Player p, String crateId) {
        CrateModel data = plugin.getConfigManager().getCrateData(crateId);
        if (data == null) return;

        Inventory gui = Bukkit.createInventory(null, 54, data.guiName + " §8- Preview");

        ItemStack cyanPane = new ItemStack(Material.CYAN_STAINED_GLASS_PANE);
        ItemMeta cpMeta = cyanPane.getItemMeta(); if (cpMeta != null) { cpMeta.setDisplayName(" "); cyanPane.setItemMeta(cpMeta); }

        ItemStack bluePane = new ItemStack(Material.LIGHT_BLUE_STAINED_GLASS_PANE);
        ItemMeta bpMeta = bluePane.getItemMeta(); if (bpMeta != null) { bpMeta.setDisplayName(" "); bluePane.setItemMeta(bpMeta); }

        for (int i = 0; i < 54; i++) {
            if (i < 9 || i > 44 || i % 9 == 0 || i % 9 == 8) gui.setItem(i, cyanPane);
            else gui.setItem(i, bluePane);
        }

        int[] slots = {10,11,12,13,14,15,16,19,20,21,22,23,24,25,28,29,30,31,32,33,34};
        int index = 0;
        for (CrateReward r : data.rewards) {
            if (index >= slots.length) break;
            ItemStack display = r.displayItem.clone();
            ItemMeta m = display.getItemMeta();
            if (m != null) {
                List<String> lore = m.hasLore() ? m.getLore() : new ArrayList<>();
                lore.add(" "); lore.add("§7Drop Chance: §e" + r.chance + "%");
                m.setLore(lore); display.setItemMeta(m);
            }
            gui.setItem(slots[index], display);
            index++;
        }
        p.openInventory(gui);
    }

    @EventHandler
    public void onInventoryClick(InventoryClickEvent e) {
        String title = e.getView().getTitle();
        if (title.contains("Preview")) {
            e.setCancelled(true);
        } else if (title.contains("Admin Panel")) {
            e.setCancelled(true);
            if (e.getCurrentItem() == null || !e.getCurrentItem().hasItemMeta()) return;

            String crateId = e.getCurrentItem().getItemMeta().getPersistentDataContainer().get(new NamespacedKey(plugin, "admin_crate_id"), PersistentDataType.STRING);
            if (crateId == null) return;

            Player p = (Player) e.getWhoClicked();
            if (e.isLeftClick()) {
                openPreviewGUI(p, crateId);
            } else if (e.isRightClick()) {
                p.getInventory().addItem(plugin.getConfigManager().generateKey(crateId, 1));
                p.sendMessage(plugin.getConfigManager().getPrefix() + " §aAdded 1x " + crateId + " key to your inventory.");
            }
        }
    }
}

class AnimationManager {
    private static final List<Location> activeAnimations = new ArrayList<>();
    public static boolean isAnimating(Location loc) { return activeAnimations.contains(loc); }

    public static void playAnimation(Player p, Location loc, List<CrateReward> rewards, CrateReward winner, String type) {
        activeAnimations.add(loc);
        new CS2ScrollAnimation(p, loc, rewards, winner).start();
    }

    public static void endAnimation(Location loc, Player p, CrateReward winner, String crateId) {
        HashMap<Integer, ItemStack> left = p.getInventory().addItem(winner.displayItem);
        if (!left.isEmpty()) {
            Item drop = p.getWorld().dropItem(p.getLocation(), winner.displayItem);
            drop.setGlowing(true);
            p.sendMessage(NexusCrates.getInstance().getConfigManager().getPrefix() + " §cYour inventory is full! Reward dropped on the ground.");
        }

        NexusCrates.getInstance().getConfigManager().triggerBroadcast(p, crateId, winner);
        Bukkit.getScheduler().runTaskLater(NexusCrates.getInstance(), () -> {
            activeAnimations.remove(loc);
            NexusCrates.getInstance().getHologramManager().unhideHologram(loc, crateId);
        }, 40L);
    }
}

class CS2ScrollAnimation {
    private final Player p; private final Location loc; private final List<CrateReward> rewards; private final CrateReward winner;
    private final ItemDisplay[] displays = new ItemDisplay[7];
    private TextDisplay liveNameHolo;
    private final Random random = new Random();

    public CS2ScrollAnimation(Player p, Location loc, List<CrateReward> r, CrateReward w) { this.p = p; this.loc = loc; this.rewards = r; this.winner = w; }

    public void start() {
        Location base = loc.clone().add(0.5, 3.5, 0.5);
        loc.getWorld().playSound(loc, Sound.BLOCK_BEACON_ACTIVATE, 1.0f, 2.0f);

        for (int i = 0; i < 7; i++) {
            float xOffset = (i - 3) * 0.9f;
            float scale = (i == 3) ? 1.0f : 0.6f;
            displays[i] = spawnDisplay(base, scale, new Vector3f(xOffset, 0, 0));
        }

        Location holoBase = base.clone().add(0, 1.0, 0);
        this.liveNameHolo = holoBase.getWorld().spawn(holoBase, TextDisplay.class, d -> {
            d.setText("§8...");
            d.setBillboard(Display.Billboard.CENTER);
            d.setShadowed(true);
        });

        new BukkitRunnable() {
            int ticks = 0;
            int shiftCount = 0;
            int maxShifts = 40;
            int speed = 1;

            @Override
            public void run() {
                if (!p.isOnline() || shiftCount >= maxShifts) { finish(); this.cancel(); return; }

                if (shiftCount > 20) speed = 2;
                if (shiftCount > 30) speed = 4;
                if (shiftCount > 35) speed = 8;
                if (shiftCount > 38) speed = 14;

                if (ticks % speed == 0) {
                    for (int i = 0; i < 6; i++) {
                        displays[i].setItemStack(displays[i+1].getItemStack());
                    }

                    if (shiftCount == maxShifts - 4) {
                        displays[6].setItemStack(winner.displayItem);
                    } else {
                        displays[6].setItemStack(rewards.get(random.nextInt(rewards.size())).displayItem);
                    }

                    ItemStack currentCenter = displays[3].getItemStack();
                    String name = (currentCenter != null && currentCenter.getItemMeta() != null && currentCenter.getItemMeta().hasDisplayName()) ? currentCenter.getItemMeta().getDisplayName() : "Reward";
                    liveNameHolo.setText(name);

                    float pitch = 2.0f - (shiftCount * 0.035f);
                    if (pitch < 0.5f) pitch = 0.5f;
                    loc.getWorld().playSound(loc, Sound.BLOCK_NOTE_BLOCK_HAT, 0.8f, pitch);

                    shiftCount++;
                }

                double angle = ticks * 0.2;
                double x = Math.cos(angle) * 1.5;
                double z = Math.sin(angle) * 1.5;
                loc.getWorld().spawnParticle(Particle.SOUL_FIRE_FLAME, loc.clone().add(0.5 + x, 0.1, 0.5 + z), 1, 0, 0, 0, 0);

                float sway = (float) Math.sin(ticks * 0.02) * 0.3f;
                for (int i = 0; i < 7; i++) {
                    float xOffset = (i - 3) * 0.9f;
                    float scale = (i == 3) ? 1.0f : 0.6f;
                    updateRotation(displays[i], new Vector3f(xOffset, 0, 0), sway, scale);
                }

                ticks++;
            }
        }.runTaskTimer(NexusCrates.getInstance(), 0L, 1L);
    }

    private ItemDisplay spawnDisplay(Location loc, float scale, Vector3f offset) {
        return loc.getWorld().spawn(loc, ItemDisplay.class, d -> {
            d.setItemStack(rewards.get(random.nextInt(rewards.size())).displayItem);
            d.setBillboard(Display.Billboard.CENTER);
            d.setTransformation(new Transformation(offset, new Quaternionf(), new Vector3f(scale, scale, scale), new Quaternionf()));
        });
    }

    private void updateRotation(ItemDisplay d, Vector3f offset, float angle, float scale) {
        d.setTransformation(new Transformation(offset, new Quaternionf().rotateY(angle), new Vector3f(scale, scale, scale), new Quaternionf()));
    }

    private void finish() {
        for (int i = 0; i < 7; i++) {
            if (i != 3 && displays[i] != null) displays[i].remove();
        }
        if (liveNameHolo != null) liveNameHolo.remove();

        displays[3].setTransformation(new Transformation(new Vector3f(0,0,0), new Quaternionf(), new Vector3f(1.2f, 1.2f, 1.2f), new Quaternionf()));
        Location c = displays[3].getLocation();

        Color fwColor = Color.WHITE;
        if (winner.chance <= 5.0) fwColor = Color.YELLOW;
        else if (winner.chance <= 20.0) fwColor = Color.PURPLE;
        else if (winner.chance <= 50.0) fwColor = Color.AQUA;

        Firework fw = (Firework) c.getWorld().spawnEntity(c, EntityType.FIREWORK_ROCKET);
        FireworkMeta fwm = fw.getFireworkMeta();
        fwm.addEffect(FireworkEffect.builder().with(FireworkEffect.Type.BALL_LARGE).withColor(fwColor).withFade(Color.WHITE).flicker(true).trail(true).build());
        fwm.setPower(0);
        fw.setFireworkMeta(fwm);
        fw.detonate();

        c.getWorld().playSound(c, Sound.UI_TOAST_CHALLENGE_COMPLETE, 1f, 1f);

        String rewardName = winner.displayItem.getItemMeta() != null && winner.displayItem.getItemMeta().hasDisplayName() ? winner.displayItem.getItemMeta().getDisplayName() : winner.displayItem.getType().name();

        p.sendMessage(" ");
        p.sendMessage("§x§F§F§D§7§0§0🎉 §lUNBOXED! §r§x§F§F§D§7§0§0🎉");
        p.sendMessage("§7You won: " + rewardName);
        p.sendMessage(" ");

        AnimationManager.endAnimation(loc, p, winner, NexusCrates.getInstance().getConfigManager().getCrateAt(loc));
        Bukkit.getScheduler().runTaskLater(NexusCrates.getInstance(), () -> { if (displays[3] != null) displays[3].remove(); }, 40L);
    }
}
